{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/validation_v1.schema.json",
  "title": "Stage 2 Validation Output Schema 1.0",
  "type": "object",
  "required": ["schema_version", "worksheet", "student_id", "answered", "blank", "missing"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "worksheet": { "type": "string" },
    "student_id": { "type": "string" },
    "answered": { "type": "integer", "minimum": 0 },
    "blank": { "type": "integer", "minimum": 0 },
    "illegible": { "type": "array", "items": { "type": "string" } },
    "missing": { "type": "array", "items": { "type": "string" } },
    "numeric_checks": { "type": "object" },
    "note": { "type": "string" }
  }
}
