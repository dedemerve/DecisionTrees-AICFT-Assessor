{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/validation_v1.schema.json",
  "title": "Technical Validation Artifact Schema 3.0",
  "type": "object",
  "required": [
    "stage",
    "worksheet",
    "student_id",
    "parse_success",
    "blocked"
  ],
  "properties": {
    "stage": {
      "const": "validation"
    },
    "worksheet": {
      "type": "string"
    },
    "student_id": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "ocr_quality": {
      "type": [
        "number",
        "null"
      ]
    },
    "parse_success": {
      "type": "boolean"
    },
    "formula_parsed": {
      "type": "boolean"
    },
    "tree_detected": {
      "type": [
        "boolean",
        "null"
      ]
    },
    "missing_regions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "deterministic_checks": {
      "type": "object"
    },
    "blocked": {
      "type": "boolean"
    },
    "blocked_reason": {
      "type": [
        "string",
        "null"
      ]
    }
  }
}
