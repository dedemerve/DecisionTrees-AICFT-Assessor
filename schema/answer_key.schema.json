{
  "title": "Worksheet Answer Key v1.0",
  "type": "object",
  "required": [
    "worksheet",
    "items"
  ],
  "additionalProperties": true,
  "properties": {
    "worksheet": {
      "$ref": "common.schema.json#/$defs/worksheet_id"
    },
    "curriculum_status": {
      "enum": [
        "deployed",
        "not_deployed"
      ]
    },
    "note": {
      "type": "string"
    },
    "items": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "check": {
            "type": "string"
          },
          "evaluation": {
            "type": "string"
          },
          "answer": {},
          "correct_answer": {},
          "example_answer": {
            "type": "string"
          },
          "tolerance": {
            "type": "number"
          },
          "accepted_forms": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "deterministic": {
            "type": "boolean"
          },
          "open_response": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
