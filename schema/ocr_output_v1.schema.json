{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/ocr_output_v1.schema.json",
  "title": "Stage 1 OCR Output Schema 1.0",
  "type": "object",
  "required": ["schema_version", "worksheet", "student_id", "responses"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "worksheet": { "type": "string" },
