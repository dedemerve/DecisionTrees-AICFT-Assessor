{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/evidence_units.schema.json",
  "title": "Canonical Evidence Units Runtime Schema 1.1",
  "description": "Layer 2 assessment-object runtime. Descriptive only — no behavioural, ILO, Domain, or AI-CFT inference.",
  "type": "object",
  "required": ["student_id", "evidence_units"],
  "additionalProperties": true,
  "properties": {
    "student_id": { "type": "string", "minLength": 1 },
    "worksheet_id": { "type": "string", "minLength": 1 },
    "evidence_units": {
      "type": "array",
      "items": { "$ref": "#/$defs/evidence_unit" }
    }
  },
  "$defs": {
    "confidence": {
      "type": "object",
      "required": ["extraction", "evidence_quality"],
      "additionalProperties": false,
      "properties": {
        "ocr": { "type": "number", "minimum": 0, "maximum": 1 },
        "extraction": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence_quality": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    "evidence_unit": {
      "type": "object",
      "required": [
        "item_id",
        "evidence_unit_type",
        "evidence_completeness",
        "content",
        "confidence"
      ],
      "additionalProperties": false,
      "properties": {
        "student_id": { "type": "string", "minLength": 1 },
        "worksheet_id": { "type": "string", "minLength": 1 },
        "item_id": { "type": "string", "minLength": 1 },
        "evidence_unit_type": {
          "enum": [
            "definition",
            "formula",
            "drawing",
            "classification",
            "rule",
            "threshold",
            "reflection",
            "prediction",
            "comparison",
            "tree_construction",
            "parameter_selection",
            "model_evaluation"
          ]
        },
        "evidence_completeness": {
          "enum": ["complete", "partial", "blank", "illegible", "missing", "unknown"]
        },
        "content": { "type": "string" },
        "confidence": { "$ref": "#/$defs/confidence" }
      }
    }
  }
}
