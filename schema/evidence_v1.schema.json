{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/evidence_v1.schema.json",
  "title": "Competency Evidence Artifact Schema 3.0",
  "type": "object",
  "required": ["schema_version", "stage", "worksheet", "student_id", "items"],
  "properties": {
    "schema_version": { "const": "3.0" },
    "stage": { "const": "evidence" },
    "worksheet": { "type": "string" },
    "student_id": { "type": "string" },
    "updated_at": { "type": "string" },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["item", "competencies"],
        "properties": {
          "item": { "type": "string" },
          "competencies": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["lo", "strength", "evidence_type", "rationale", "evidence_present"],
              "properties": {
                "lo": { "type": "string", "pattern": "^LO3\\." },
                "strength": {
                  "enum": ["none", "weak", "moderate", "strong"]
                },
                "evidence_type": {
                  "enum": ["direct", "supporting", "application", "early_indicator", "reflective", "prior_belief"]
                },
                "rationale": { "type": "string", "minLength": 1 },
                "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
                "evidence_present": { "type": "boolean" }
              }
            }
          },
          "learning_objects": {
            "description": "Legacy v2.1 field — use competencies instead",
            "type": "array"
          }
        }
      }
    }
  }
}
