{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/domain_understanding.schema.json",
  "title": "Domain Understanding ontology",
  "type": "object",
  "required": [
    "artifact",
    "ontology_layer",
    "design_constraint",
    "construct",
    "domains"
  ],
  "additionalProperties": true,
  "properties": {
    "artifact": {
      "const": "domain_understanding_ontology"
    },
    "ontology_layer": {
      "const": "assessment_construct"
    },
    "design_constraint": {
      "type": "string",
      "minLength": 50
    },
    "construct": {
      "type": "string"
    },
    "domain_count": {
      "type": "integer",
      "minimum": 1
    },
    "domains": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "$ref": "#/$defs/domain"
      }
    }
  },
  "$defs": {
    "domain": {
      "type": "object",
      "required": [
        "id",
        "title",
        "construct_dimension",
        "assessment_construct_type",
        "construct_definition",
        "theoretical_rationale",
        "evidence_criteria",
        "convergence_requirements",
        "contradiction_handling",
        "indicative_ilos",
        "not_equivalent_to"
      ],
      "additionalProperties": true,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^DU_[A-Z][A-Z0-9_]+$"
        },
        "title": {
          "type": "string"
        },
        "construct_dimension": {
          "enum": [
            "conceptual",
            "procedural",
            "strategic",
            "reflective"
          ]
        },
        "assessment_construct_type": {
          "const": "emergent"
        },
        "construct_definition": {
          "type": "string",
          "minLength": 20
        },
        "theoretical_rationale": {
          "type": "string",
          "minLength": 10
        },
        "evidence_criteria": {
          "type": "object",
          "required": [
            "counts",
            "does_not_count"
          ],
          "properties": {
            "counts": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "string"
              }
            },
            "does_not_count": {
              "type": "array",
              "minItems": 2,
              "items": {
                "type": "string"
              }
            }
          }
        },
        "convergence_requirements": {
          "type": "object",
          "required": [
            "minimum_distinct_ilos"
          ],
          "additionalProperties": true
        },
        "confusable_with": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "construct",
              "distinction"
            ],
            "properties": {
              "construct": {
                "type": "string"
              },
              "distinction": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}
