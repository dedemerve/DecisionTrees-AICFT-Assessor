{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/summary_v1.schema.json",
  "title": "Worksheet Summary Artifact Schema 3.0",
  "description": "Derived scorecard view only. Do not persist summary.json — build from scoring.json via student_bundle.build_summary_from_scoring().",
  "type": "object",
  "required": [
    "stage",
    "worksheet",
    "student_id",
    "max_score",
    "review_items"
  ],
  "properties": {
    "stage": {
      "const": "summary"
    },
    "worksheet": {
      "type": "string"
    },
    "student_id": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "total_score": {
      "type": [
        "number",
        "null"
      ]
    },
    "max_score": {
      "type": "number"
    },
    "review_items": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocked": {
      "type": "boolean"
    },
    "blocked_reason": {
      "type": "string"
    }
  }
}
