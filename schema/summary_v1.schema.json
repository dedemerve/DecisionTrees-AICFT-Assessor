{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/summary_v1.schema.json",
  "title": "Stage 4 Summary Output Schema 1.0",
  "type": "object",
  "required": ["schema_version", "worksheet", "student_id", "total_score", "max_score", "learning_outcomes"],
  "properties": {
    "schema_version": { "const": "1.0" },
    "worksheet": { "type": "string" },
    "student_id": { "type": "string" },
    "total_score": { "type": ["number", "null"] },
    "max_score": { "type": "number" },
    "learning_outcomes": {
      "type": "object",
      "additionalProperties": {
        "enum": ["none", "weak", "moderate", "strong"]
      }
    },
    "incomplete": { "type": "boolean" },
    "incomplete_reason": { "type": "string" },
    "blocked": { "type": "boolean" },
    "blocked_reason": { "type": "string" }
  }
}
