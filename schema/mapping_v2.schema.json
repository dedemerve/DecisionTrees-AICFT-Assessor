{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/mapping_v2.schema.json",
  "title": "Worksheet Competency Mapping Schema 2.0",
  "type": "object",
  "required": [
    "worksheet",
    "framework",
    "items"
  ],
  "properties": {
    "worksheet": {
      "type": "string"
    },
    "framework": {
      "type": "string"
    },
    "note": {
      "type": "string"
    },
    "items": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "minItems": 1,
        "items": {
          "type": "object",
          "required": [
            "lo",
            "strength",
            "evidence_type",
            "expected_level",
            "rationale",
            "role",
            "portfolio_weight"
          ],
          "properties": {
            "lo": {
              "type": "string",
              "pattern": "^LO3\\."
            },
            "strength": {
              "enum": [
                "weak",
                "moderate",
                "strong"
              ]
            },
            "evidence_type": {
              "enum": [
                "direct",
                "supporting",
                "application",
                "early_indicator",
                "reflective",
                "prior_belief"
              ]
            },
            "expected_level": {
              "enum": [
                "Acquire",
                "Deepen",
                "Create"
              ]
            },
            "rationale": {
              "type": "string",
              "minLength": 10
            },
            "role": {
              "enum": [
                "primary",
                "supporting"
              ]
            },
            "portfolio_weight": {
              "enum": [
                "full",
                "baseline",
                "diagnostic"
              ]
            }
          },
          "additionalProperties": false
        }
      }
    }
  },
  "additionalProperties": false
}
