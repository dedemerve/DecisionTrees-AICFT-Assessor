{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/student_extraction.schema.json",
  "title": "Student worksheet extraction artifact (pipeline stage envelope)",
  "description": "students/<id>/<WS>/extraction.json — OCR responses only; not the worksheet bundle extraction_schema.json template.",
  "type": "object",
  "required": [
    "stage",
    "student_id",
    "worksheet",
    "responses"
  ],
  "additionalProperties": true,
  "properties": {
    "stage": {
      "const": "extraction"
    },
    "student_id": {
      "type": "string",
      "minLength": 1
    },
    "worksheet": {
      "$ref": "common.schema.json#/$defs/worksheet_id"
    },
    "schema_version": {
      "type": "string"
    },
    "updated_at": {
      "type": "string"
    },
    "responses": {
      "type": "object",
      "additionalProperties": {
        "type": "string"
      }
    },
    "layout_roi": {
      "type": "object"
    },
    "numeric_table": {
      "type": "object"
    },
    "htr_status": {
      "type": "string"
    }
  }
}
