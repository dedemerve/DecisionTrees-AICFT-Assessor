{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/portfolio.schema.json",
  "title": "AI-CFT Portfolio Schema 4.0 (simple LO rubric)",
  "type": "object",
  "required": [
    "framework",
    "aspect",
    "methodology",
    "worksheets_scored",
    "lo_review_packets",
    "evidence_by_lo",
    "researcher_rubric_decisions",
    "data_gaps",
    "evidence_item_count"
  ],
  "properties": {
    "student_id": {
      "type": "string",
      "minLength": 1
    },
    "framework": {
      "type": "string"
    },
    "aspect": {
      "type": "string"
    },
    "methodology": {
      "type": "object",
      "required": [
        "approach",
        "aggregation_note"
      ],
      "properties": {
        "approach": {
          "type": "string",
          "enum": [
            "simple_lo_rubric",
            "ecd_v1"
          ],
          "description": "Assessment methodology tag — distinguishes simple rubric from archived ECD chain."
        },
        "aggregation_note": {
          "type": "string",
          "minLength": 1
        },
        "ecd_archive": {
          "type": "string"
        }
      },
      "additionalProperties": true
    },
    "lo_reference_source": {
      "type": "string"
    },
    "worksheets_scored": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "lo_review_packets": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "string"
      }
    },
    "evidence_by_lo": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "object",
          "required": [
            "source",
            "excerpt"
          ],
          "properties": {
            "source": {
              "enum": [
                "worksheet",
                "codap_log",
                "screen_recording"
              ]
            },
            "excerpt": {
              "type": "string",
              "minLength": 1
            },
            "timestamp": {
              "type": [
                "string",
                "null"
              ]
            },
            "worksheet": {
              "type": [
                "string",
                "null"
              ]
            },
            "item_id": {
              "type": [
                "string",
                "null"
              ]
            }
          },
          "additionalProperties": false
        }
      }
    },
    "researcher_rubric_decisions": {
      "type": "array",
      "description": "May be empty while researcher review is pending.",
      "items": {
        "type": "object",
        "required": [
          "lo_code",
          "candidate_id",
          "decision",
          "supporting_evidence",
          "researcher_note"
        ],
        "properties": {
          "lo_code": {
            "type": "string",
            "pattern": "^LO3\\."
          },
          "candidate_id": {
            "type": "string",
            "minLength": 1
          },
          "decision": {
            "enum": [
              "met",
              "partial",
              "not_met",
              "insufficient_data"
            ]
          },
          "supporting_evidence": {
            "type": "array",
            "minItems": 1
          },
          "researcher_note": {
            "type": "string",
            "minLength": 8
          }
        },
        "additionalProperties": false
      }
    },
    "data_gaps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "worksheet",
          "items",
          "priority",
          "why"
        ],
        "properties": {
          "worksheet": {
            "type": "string"
          },
          "items": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "priority": {
            "type": "integer",
            "minimum": 1,
            "maximum": 9
          },
          "why": {
            "type": "string",
            "minLength": 1
          }
        },
        "additionalProperties": false
      }
    },
    "evidence_item_count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "additionalProperties": false
}
