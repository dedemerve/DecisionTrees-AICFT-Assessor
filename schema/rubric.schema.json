{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://decisiontrees-aicft-assessor/rubric.schema.json",
  "title": "ProDaBi Worksheet Rubric Schema 3.0",
  "type": "object",
  "required": [
    "worksheet",
    "items"
  ],
  "additionalProperties": true,
  "properties": {
    "worksheet": {
      "type": "string",
      "pattern": "^(WS\\d+|WS_DT|WS10)$"
    },
    "note": {
      "type": "string"
    },
    "blocked_note": {
      "type": "string"
    },
    "dataset_size": {
      "type": "number"
    },
    "dataset_note": {
      "type": "string"
    },
    "rows": {
      "type": "array"
    },
    "items": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/rubric_item"
      }
    }
  },
  "$defs": {
    "component": {
      "type": "object",
      "required": [
        "id",
        "idea"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "minLength": 1
        },
        "idea": {
          "type": "string",
          "minLength": 1
        },
        "required": {
          "type": "boolean",
          "default": true
        }
      }
    },
    "rubric_item": {
      "type": "object",
      "required": [
        "max_score"
      ],
      "additionalProperties": true,
      "properties": {
        "max_score": {
          "type": "number",
          "minimum": 0
        },
        "evaluation": {
          "type": "string"
        },
        "check": {
          "type": "string"
        },
        "answer": {},
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/component"
          }
        },
        "need": {
          "type": "integer",
          "minimum": 1
        },
        "partial_on": {
          "type": "integer",
          "minimum": 0
        },
        "partial_score": {
          "type": "number",
          "minimum": 0
        },
        "example_answer": {
          "type": "string"
        },
        "statement": {
          "type": "string"
        },
        "correct_answer": {},
        "correct": {
          "type": "boolean"
        },
        "fields": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "accepted_forms": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
